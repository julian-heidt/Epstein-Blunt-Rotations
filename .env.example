# Copy this to .env and fill in real values before deploying

# MongoDB credentials
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change-me-please

# Your public-facing domain(s) - comma-separated, no trailing slash.
# NPM (Nginx Proxy Manager) handles SSL termination; list your domain
# so CORS headers are correct if the API is ever hit cross-origin.
# Example: ALLOWED_ORIGINS=https://evilblunts.org,http://localhost:3500
ALLOWED_ORIGINS=https://evilblunts.org,http://localhost:3500
